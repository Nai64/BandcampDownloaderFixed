<Window
    x:Class="BandcampDownloader.UI.Dialogs.WindowDiscographySelection"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:extraction="clr-namespace:BandcampDownloader.Bandcamp.Extraction"
    Title="Select Releases to Download"
    Width="660"
    Height="500"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,10"
            FontWeight="Bold"
            Text="Select the releases you want to download:"
            TextWrapping="Wrap" />

        <!-- Selection buttons -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,10"
            Orientation="Horizontal">
            <Button
                Width="100"
                Height="25"
                Margin="0,0,5,0"
                Click="ButtonSelectAll_Click"
                Content="Select All" />
            <Button
                Width="100"
                Height="25"
                Margin="0,0,5,0"
                Click="ButtonDeselectAll_Click"
                Content="Deselect All" />
            <TextBlock
                x:Name="TextBlockSelectedCount"
                VerticalAlignment="Center"
                Margin="10,0,0,0">
                <Run Text="Selected:" />
                <Run Text="0" />
                <Run Text="/" />
                <Run Text="0" />
            </TextBlock>
        </StackPanel>

        <!-- Album list -->
        <ListView
            x:Name="ListViewAlbums"
            Grid.Row="2"
            Height="350"
            ItemsSource="{Binding}"
            SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox
                                    HorizontalAlignment="Center"
                                    Background="White"
                                    BorderBrush="Black"
                                    BorderThickness="1"
                                    IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Click="CheckBox_Click" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn
                        Width="400"
                        DisplayMemberBinding="{Binding Title}"
                        Header="Title" />
                    <GridViewColumn
                        Width="80"
                        DisplayMemberBinding="{Binding Type}"
                        Header="Type" />
                    <GridViewColumn Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button
                                    Width="50"
                                    Height="20"
                                    HorizontalAlignment="Center"
                                    Content="Open"
                                    Click="ButtonOpenUrl_Click" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- OK/Cancel buttons -->
        <StackPanel
            Grid.Row="3"
            Margin="0,10,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="25"
                Margin="0,0,5,0"
                Click="ButtonOK_Click"
                Content="OK"
                IsDefault="True" />
            <Button
                Width="80"
                Height="25"
                Click="ButtonCancel_Click"
                Content="Cancel"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
