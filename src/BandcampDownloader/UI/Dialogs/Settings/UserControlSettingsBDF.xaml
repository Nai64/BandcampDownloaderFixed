<UserControl
    x:Class="BandcampDownloader.UI.Dialogs.Settings.UserControlSettingsBDF"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lex="http://wpflocalizeextension.codeplex.com"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="clr-namespace:BandcampDownloader.Settings"
    Width="410"
    Height="Auto"
    MaxHeight="326"
    lex:LocalizeDictionary.DesignCulture="en"
    lex:ResxLocalizationProvider.DefaultAssembly="BandcampDownloader"
    lex:ResxLocalizationProvider.DefaultDictionary="Resources"
    d:DataContext="{d:DesignInstance settings:IUserSettings}"
    KeyboardNavigation.TabNavigation="Local"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid x:Name="GridMain" VerticalAlignment="Top">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
        </Grid.RowDefinitions>
        <CheckBox
            x:Name="CheckBoxContinueOnError"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding ContinueOnError, UpdateSourceTrigger=Explicit}"
            IsEnabled="True"
            TabIndex="0"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxWaitForFileAfterDownload"
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding WaitForFileAfterDownload, UpdateSourceTrigger=Explicit}"
            IsEnabled="True"
            TabIndex="1"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxIgnoreTracksLongerThan"
            Grid.Row="2"
            Grid.Column="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding IgnoreTracksLongerThan, UpdateSourceTrigger=Explicit}"
            IsEnabled="True"
            TabIndex="2"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <Slider
            x:Name="SliderIgnoreTracksLongerThanMinutes"
            Grid.Row="2"
            Grid.Column="1"
            Margin="10,0,10,0"
            VerticalAlignment="Center"
            IsEnabled="{Binding ElementName=CheckBoxIgnoreTracksLongerThan, Path=IsChecked}"
            Maximum="60"
            Minimum="1"
            TabIndex="3"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000"
            Value="{Binding IgnoreTracksLongerThanMinutes, UpdateSourceTrigger=Explicit}" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="2"
            Margin="0,0,5,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MinWidth="50"
            IsEnabled="{Binding ElementName=CheckBoxIgnoreTracksLongerThan, Path=IsChecked}"
            TextAlignment="Center"
            Text="{Binding Value, ElementName=SliderIgnoreTracksLongerThanMinutes, StringFormat={}{0:F0} min}" />
        <CheckBox
            x:Name="CheckBoxAssignAlbumArtistToAllTracks"
            Grid.Row="3"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding AssignAlbumArtistToAllTracks, UpdateSourceTrigger=Explicit}"
            IsEnabled="True"
            TabIndex="4"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxSplitVariousArtistsTrackTitles"
            Grid.Row="4"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding SplitVariousArtistsTrackTitles, UpdateSourceTrigger=Explicit}"
            IsEnabled="True"
            TabIndex="5"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxShowTrackCountText"
            Grid.Row="5"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding ShowTrackCountText, UpdateSourceTrigger=Explicit}"
            IsEnabled="True"
            TabIndex="6"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxForceBitrate"
            Grid.Row="6"
            Grid.Column="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding ForceBitrate, UpdateSourceTrigger=Explicit}"
            IsEnabled="True"
            TabIndex="7"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <ComboBox
            x:Name="ComboBoxBitrate"
            Grid.Row="6"
            Grid.Column="1"
            Width="100"
            Height="22"
            Margin="5,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            IsEnabled="{Binding ElementName=CheckBoxForceBitrate, Path=IsChecked}"
            SelectedValue="{Binding Bitrate, UpdateSourceTrigger=Explicit}"
            SelectedValuePath="Content"
            SelectionChanged="ComboBoxBitrate_SelectionChanged"
            TabIndex="8"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000">
            <ComboBoxItem Content="32" />
            <ComboBoxItem Content="40" />
            <ComboBoxItem Content="48" />
            <ComboBoxItem Content="56" />
            <ComboBoxItem Content="64" />
            <ComboBoxItem Content="80" />
            <ComboBoxItem Content="96" />
            <ComboBoxItem Content="112" />
            <ComboBoxItem Content="128" />
            <ComboBoxItem Content="192" />
            <ComboBoxItem Content="256" />
            <ComboBoxItem Content="320" />
        </ComboBox>
        <CheckBox
            x:Name="CheckBoxShowOriginalDownloadSize"
            Grid.Row="7"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="18,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding ShowOriginalDownloadSize, UpdateSourceTrigger=Explicit}"
            IsEnabled="{Binding ElementName=CheckBoxForceBitrate, Path=IsChecked}"
            TabIndex="9"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxEnableToastNotifications"
            Grid.Row="8"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding EnableToastNotifications, UpdateSourceTrigger=Explicit}"
            IsEnabled="True"
            TabIndex="10"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxToastOnDownloadComplete"
            Grid.Row="9"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="18,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding ToastOnDownloadComplete, UpdateSourceTrigger=Explicit}"
            IsEnabled="{Binding ElementName=CheckBoxEnableToastNotifications, Path=IsChecked}"
            TabIndex="11"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxToastOnDownloadError"
            Grid.Row="10"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="18,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding ToastOnDownloadError, UpdateSourceTrigger=Explicit}"
            IsEnabled="{Binding ElementName=CheckBoxEnableToastNotifications, Path=IsChecked}"
            TabIndex="12"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxToastOnAlbumComplete"
            Grid.Row="11"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="18,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding ToastOnAlbumComplete, UpdateSourceTrigger=Explicit}"
            IsEnabled="{Binding ElementName=CheckBoxEnableToastNotifications, Path=IsChecked}"
            TabIndex="13"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxToastOnTrackSkipped"
            Grid.Row="12"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="18,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding ToastOnTrackSkipped, UpdateSourceTrigger=Explicit}"
            IsEnabled="{Binding ElementName=CheckBoxEnableToastNotifications, Path=IsChecked}"
            TabIndex="14"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxShowDetailedErrorDialog"
            Grid.Row="13"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding ShowDetailedErrorDialog, UpdateSourceTrigger=Explicit}"
            IsEnabled="True"
            TabIndex="15"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
        <CheckBox
            x:Name="CheckBoxEnableDiscographySelectionDialog"
            Grid.Row="14"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{lex:Loc}"
            IsChecked="{Binding EnableDiscographySelectionDialog, UpdateSourceTrigger=Explicit}"
            IsEnabled="True"
            TabIndex="16"
            ToolTip="{lex:Loc}"
            ToolTipService.ShowDuration="60000" />
    </Grid>
    </ScrollViewer>
</UserControl>
